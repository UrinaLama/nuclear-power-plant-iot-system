    {
        "id": "3ba0319a19e821b2",
        "type": "function",
        "z": "a24ce6732882ebc7",
        "name": "function 4",
        "func": "let data = msg.payload;\n\n// If payload is a string, parse it\nif (typeof data === \"string\") {\n    try {\n        data = JSON.parse(data);\n    } catch (err) {\n        node.error(\"JSON parse failed: \" + data, msg);\n        return null;\n    }\n}\n\n// Now data is guaranteed to be an object\nconst temp = Number(data.temperature);\nconst pressure = Number(data.pressure);\n\n// Validate numeric values\nif (isNaN(temp) || isNaN(pressure)) {\n    node.error(\"Invalid sensor values: \" + JSON.stringify(data), msg);\n    return null;\n}\n\n// Prepare payload for InfluxDB\nmsg.payload = {\n    temperature: temp,\n    pressure: pressure\n};\n\nreturn msg;\n",
