    {
        "id": "81afaf987d11f434",
        "type": "function",
        "z": "43a873bd561270b5",
        "name": "JSON objects",
        "func": "// Extract field name from topic\nlet field = msg.topic.split(\"/\").pop();\n\n// Accumulate fields\nlet row = flow.get(\"row\") || {};\nrow[field] = Number(msg.payload);\nflow.set(\"row\", row);\n\n// Expected fields\nconst expected = [\n  \"t_sec\", \"P\", \"TAVG\", \"LVPZ\", \"LVCR\",\n  \"PWNT\", \"PRB\", \"CNH2\", \"RM1\", \"DWB\", \"DTHY\"\n];\n\n// Wait until row complete\nif (!expected.every(k => row[k] !== undefined)) {\n  return null;\n}\n\n// ✔ REQUIRED BY influxdb out node\nmsg.measurement = \"reactor-coolant\";\n\n// ✔ payload must be ONLY numeric fields\nmsg.payload = row;\n\n// optional tags\nmsg.tags = {\n  source: \"simulator\"\n};\n\n// reset for next cycle\nflow.set(\"row\", {});\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 380,
        "y": 240,
        "wires": [
            [
                "937a421df93d6573"
            ]
        ]
    },
    {
        "id": "798ae18932350d91",
        "type": "function",
        "z": "43a873bd561270b5",
        "name": "Alert",
        "func": "// ---- Store latest values ----\nif (msg.topic.endsWith(\"/P\")) {\n    flow.set(\"pressure\", Number(msg.payload));\n    return null;\n}\n\nif (msg.topic.endsWith(\"/RM1\")) {\n    flow.set(\"radiation-monitor\", Number(msg.payload));\n    return null;\n}\n\n// ---- Read stored values ----\nconst pressure = flow.get(\"pressure\");\nconst radiation = flow.get(\"radiation-monitor\");\n\nif (pressure === undefined || radiation === undefined) {\n    return null;\n}\n\n// ---- Round values ----\nconst P = Number(pressure.toFixed(4));\nconst RM1 = Number(radiation.toFixed(4));\n\n// ---- Alert condition ----\nconst alertCondition =\n    (P < 148.00 && RM1 > 0.01) ||  // Pressure drop + small RM1 rise\n    (RM1 > 0.14);               // Critical RM1 spike\n\nif (!alertCondition) {\n    return null;\n}\n\n// ---- Cooldown logic (3 minutes) ----\nconst now = Date.now();\nconst lastAlert = flow.get(\"lastAlertTime\") || 0;\nconst COOLDOWN = 1 * 60 * 1000; // 1 minutes\n\nif (now - lastAlert < COOLDOWN) {\n    return null; // still in cooldown\n}\n\n// ---- Save alert time ----\nflow.set(\"lastAlertTime\", now);\n\n// ---- Telegram message ----\nlet alertMessage = \"\";\n\nif (P < 148.00 && RM1 > 0.01) {\n    alertMessage = `Loss of coolant system detected!\nRM1: ${RM1} CPM\nPressure: ${P} bar\nTriggered: Pressure drop and Radiation increases`;\n} else if (RM1 > 0.14) {\n    alertMessage = `Loss of coolant system detected!!\nPressure: ${P} bar\nRM1: ${RM1} CPM\n\nTriggered: Radiation increases inside the containment`;\n}\n\nmsg.payload = {\n    chatId: 1881480328,   // Replace with your Telegram chat ID\n    type: \"message\",\n    content: alertMessage\n};\n\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 350,
        "y": 300,
        "wires": [
            [
                "600b68289e366c50"
            ]
        ]
    },
