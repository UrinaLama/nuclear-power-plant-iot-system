    {
        "id": "cb45d1d9a07f347e",
        "type": "function",
        "z": "a24ce6732882ebc7",
        "name": "function 5",
        "func": "// If payload is a string, try to parse it as JSON\nif (typeof msg.payload === \"string\") {\n    try {\n        msg.payload = JSON.parse(msg.payload);\n    } catch (e) {\n        node.warn(\"Payload is not valid JSON\");\n        return null;\n    }\n}\n\n// Ensure payload is an object now\nif (typeof msg.payload !== \"object\" || msg.payload === null) {\n    node.warn(\"Payload is not an object\");\n    return null;\n}\n\nconst temp = Number(msg.payload.temperature);\nconst pressure = Number(msg.payload.pressure);\n\n// Validate values\nif (isNaN(temp) || isNaN(pressure)) {\n    node.warn(\"Temperature or pressure missing\");\n    return null;\n}\n\n// Alert condition\nif (temp > 70 || pressure > 120) {\n    // Format message as object for Telegram node\n    msg.payload = {\n        chatId: 1881480328,  // <-- your user chat ID\n        type: \"message\",     \n        content: `ALERT! Thermo-Hydraulic values high\nTemperature: ${temp} °C\nPressure: ${pressure} kPa`\n    };\n    return msg; // Only return if alert should be sent\n}\n\n// No alert → stop flow\nreturn null;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
